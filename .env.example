# Environment Variables for Segecha Group Website

# ─────────────────────────────────────────
# SITE CONFIG
# ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://segecha.com

# ─────────────────────────────────────────
# GOOGLE ANALYTICS
# ─────────────────────────────────────────
# Replace with your GA4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────
# EMAIL (for quote form submissions)
# Option A: Resend (recommended)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: SMTP/Nodemailer
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@segecha.com
# QUOTE_EMAIL_TO=info@segecha.com

# ─────────────────────────────────────────
# WHATSAPP (optional - for webhook-based quotes)
# ─────────────────────────────────────────
# WHATSAPP_API_URL=https://wa.me/254107971792
